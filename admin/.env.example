# ─── ADMIN ENVIRONMENT VARIABLES ─────────────────────────────────────────────
# For local dev: Vite proxies /api → localhost:5000 automatically.
# You do NOT need VITE_API_URL locally.
#
# For Vercel: add each VITE_* variable in Project Settings → Environment Variables.
# Vercel bakes these into the build bundle at build time.

# ── API URL (REQUIRED for production) ────────────────────────────────────────
# Set this to your deployed server Vercel URL.
# Example: https://omnideal-server.vercel.app/api
VITE_API_URL=https://your-server.vercel.app/api

# ── Client store URL (optional — used for "View Store" link in sidebar) ───────
VITE_CLIENT_URL=https://your-client.vercel.app
